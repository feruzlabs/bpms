<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_2"
                  targetNamespace="http://bpms.local/test">
  <bpmn:process id="FormProcess" isExecutable="true">
    <bpmn:startEvent id="Start"/>
    <bpmn:userTask id="FormTask" name="Collect">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="note" label="Note" type="string" defaultValue=""/>
          <camunda:formField id="collect" label="Collect" type="bpmn_collect_data">
            <camunda:properties>
              <camunda:property id="max_size" value="5"/>
              <camunda:property id="parameters" value="[{&quot;parameter_name&quot;:&quot;title&quot;}]"/>
            </camunda:properties>
            <camunda:validation>
              <camunda:constraint name="required" config="true"/>
            </camunda:validation>
          </camunda:formField>
        </camunda:formData>
      </bpmn:extensionElements>
    </bpmn:userTask>
    <bpmn:endEvent id="End"/>
    <bpmn:sequenceFlow id="f1" sourceRef="Start" targetRef="FormTask"/>
    <bpmn:sequenceFlow id="f2" sourceRef="FormTask" targetRef="End"/>
  </bpmn:process>
</bpmn:definitions>