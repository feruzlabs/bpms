<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  targetNamespace="https://bpms.new">
  <bpmn:process id="demo-credit-scoring" name="Demo credit scoring" isExecutable="true">
    <bpmn:startEvent id="start"/>

    <bpmn:serviceTask id="score" name="Score">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:connectorId>demo-credit-score</camunda:connectorId>
          <camunda:inputOutput>
            <camunda:inputParameter name="amount">amount.doubleValue()</camunda:inputParameter>
            <camunda:inputParameter name="monthlyIncome">monthlyIncome.doubleValue()</camunda:inputParameter>
          </camunda:inputOutput>
        </camunda:connector>
      </bpmn:extensionElements>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="decision" default="toReject"/>
    <bpmn:endEvent id="approved"/>
    <bpmn:endEvent id="rejected"/>

    <bpmn:sequenceFlow id="toScore"    sourceRef="start" targetRef="score"/>
    <bpmn:sequenceFlow id="toDecision" sourceRef="score" targetRef="decision"/>
    <bpmn:sequenceFlow id="toApprove"  sourceRef="decision" targetRef="approved">
      <bpmn:conditionExpression>score.intValue() &gt;= 50</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="toReject"   sourceRef="decision" targetRef="rejected"/>
  </bpmn:process>
</bpmn:definitions>
